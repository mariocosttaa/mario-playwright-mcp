+    if (SENSITIVE_KEYS.test(key))
+      filtered[key] = "***";
+    else if (v != null)
+      filtered[key] = String(v).length > 200 ? String(v).slice(0, 200) + "..." : String(v);
+  }
+  return JSON.stringify(filtered, null, 2);
+}
