+const SENSITIVE_KEYS = /\b(password|token|secret|authorization|cookie|api[_-]?key)\b/i;
+
+function redactObject(obj, depth) {
+  if (depth > 10)
+    return "[max depth]";
+  if (obj === null || obj === undefined)
